# Copy to .env and adjust as needed. Every value has a sensible default, so the
# app runs with NO .env file at all. This file documents what can be configured.

# --- Core Django ---
# SECRET_KEY=change-me-in-production
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1

# --- CORS (React dev server origins) ---
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Dataset ---
# Path to the CSV loaded by `manage.py load_dataset` and used as the upload fallback.
# DEFAULT_DATASET_PATH=./shifts/data/shift_data.csv

# --- Analysis policy (all data-derived by default; override only if you want) ---
# Reasons treated as non-productive in the Operational Efficiency Score:
# NON_PRODUCTIVE_REASONS=Breakdown,Unknown Failure
#
# Optional grouping of raw reasons into higher-level buckets (JSON):
# REASON_GROUPS={"Equipment Failure": ["Breakdown", "Machine Jam", "Unknown Failure"]}
#
# Named target sets for the breakdown-streak engine (JSON):
# STREAK_PRESETS={"breakdown": ["Breakdown"], "failure_family": ["Breakdown", "Power Failure", "Machine Jam", "Unknown Failure"]}
