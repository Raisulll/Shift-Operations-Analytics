# Copy to .env and adjust as needed. Every value has a sensible default, so the
# app runs with NO .env file at all. This file documents what can be configured.

# --- Core Django ---
# SECRET_KEY=change-me-in-production
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
# On Render, RENDER_EXTERNAL_HOSTNAME is injected automatically and trusted.

# --- Database ---
# Unset -> local SQLite (zero setup). Set to a Postgres URL in production; Render
# injects this automatically from the attached database. Example:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# --- CORS (frontend origins allowed to call the API) ---
# Dev (Vite):
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production: set to your Vercel URL, e.g.
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# Optional: allow Vercel preview URLs via regex
# CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$
# CSRF trust for admin/browsable API over HTTPS (the Render host is auto-trusted):
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# --- Dataset ---
# Path to the CSV loaded by `manage.py load_dataset` and used as the upload fallback.
# DEFAULT_DATASET_PATH=./shifts/data/shift_data.csv

# --- Analysis policy (all data-derived by default; override only if you want) ---
# Reasons treated as non-productive in the Operational Efficiency Score:
# NON_PRODUCTIVE_REASONS=Breakdown,Unknown Failure
#
# Optional grouping of raw reasons into higher-level buckets (JSON):
# REASON_GROUPS={"Equipment Failure": ["Breakdown", "Machine Jam", "Unknown Failure"]}
#
# Named target sets for the breakdown-streak engine (JSON):
# STREAK_PRESETS={"breakdown": ["Breakdown"], "failure_family": ["Breakdown", "Power Failure", "Machine Jam", "Unknown Failure"]}
