# Copy to .env only if you need to override defaults.

# The frontend calls the API at this base URL. Defaults to the dev proxy '/api'
# (see vite.config.js), which forwards to the Django server on :8000.
# VITE_API_BASE=/api
#
# In production (Vercel) there is no dev proxy, so set this to your deployed
# backend's full API URL, e.g.:
# VITE_API_BASE=https://shift-analytics-api.onrender.com/api

# If the backend runs somewhere other than http://127.0.0.1:8000, point the
# dev proxy at it here.
# VITE_API_PROXY=http://127.0.0.1:8000
